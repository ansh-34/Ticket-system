# Port the HTTP server listens on. Defaults to 8080 if unset.
PORT=8080

# Secret used to sign JWTs. REQUIRED in production — use a long random string.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# JWT lifetime in hours. Defaults to 24 if unset.
JWT_TTL_HOURS=24
